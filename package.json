{
  "name": "rsps-hub",
  "version": "1.0.36",
  "description": "RSPS Hub Launcher",
  "author": "RSPS Hub",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node scripts/prebuild-jar.js",
    "build": "electron-builder",
    "build:skip-jar": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.rspshub.launcher",
    "productName": "RSPS Hub",
    "win": {
      "target": "nsis",
      "artifactName": "RSPSHub-Setup-v${version}.${ext}"
    },
    "nsis": {
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "extraResources": [
      {
        "from": "java-backend/",
        "to": "java-backend/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Vinnlarr",
      "repo": "rsps-hub-electron"
    }
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  }
}
