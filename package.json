{
  "name": "rsps-hub",
  "version": "1.0.66",
  "description": "RSPS Hub Launcher",
  "author": "RSPS Hub",
  "main": "main.js",
  "scripts": {
    "prestart": "node scripts/prebuild-jar.js",
    "start": "electron .",
    "prebuild": "node scripts/prebuild-jar.js",
    "build": "electron-builder",
    "build:skip-jar": "electron-builder",
    "release": "node tools/release.js"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.rspshub.launcher",
    "productName": "RSPS Hub",
    "afterPack": "build/afterPack.js",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "RSPSHub-Setup-v${version}.${ext}"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": [
          "x64"
        ]
      },
      "icon": "build/icon.icns",
      "category": "public.app-category.games",
      "artifactName": "RSPSHub-Setup-v${version}-mac-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extraResources": [
        {
          "from": "java-backend-mac/jre",
          "to": "java-backend/jre",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Game",
      "artifactName": "RSPSHub-Setup-v${version}-linux-${arch}.${ext}",
      "extraResources": [
        {
          "from": "java-backend-linux/jre",
          "to": "java-backend/jre",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "java-backend/",
        "to": "java-backend/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Vinnlarr",
      "repo": "rsps-hub-electron"
    }
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  }
}
