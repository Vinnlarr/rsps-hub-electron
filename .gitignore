node_modules/
dist/
java-backend/
# Mac bundled JRE — too big for git (~110 MB). CI downloads it on demand
# (see .github/workflows/build-mac.yml), and Mac devs running `npm run build`
# locally already have it from the workflow run or can re-download.
java-backend-mac/
# Same deal for Linux. CI downloads from Adoptium in build-linux.yml.
java-backend-linux/
.claude/
*.log
RSPSHub.jar
badge-preview.html
.idea/

# Ops / deploy scripts — these may embed VPS + DB credentials. NEVER commit.
# Glob the contents instead of the dir itself so we can re-include the
# prebuild hook below (git ignore can't re-include files under an excluded dir).
scripts/*
# ...except the prebuild hook, which is part of the build and ships no secrets.
!scripts/prebuild-jar.js
.env
.env.*
*.pem
*.key
credentials*
NEW_CREDENTIALS*

# Local mirror of VPS PHP endpoints (deployed via scp; not part of the app).
_vps_videos/
